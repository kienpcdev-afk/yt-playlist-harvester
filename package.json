{
  "name": "tooldownload",
  "version": "1.0.0",
  "description": "Tool tải playlist YouTube",
  "main": "windownserver.js",
  "bin": "windownserver.js",
  "scripts": {
    "start": "node server.js",
    "start:win": "node windownserver.js",
    "dev": "node server.js",
    "setup:cookies": "node scripts/setup-cookies.js",
    "setup:browser-cookies": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-browser-cookies.ps1",
