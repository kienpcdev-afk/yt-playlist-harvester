PORT=3000

# Số video tải song song (mặc định 2, tối đa 4)
DOWNLOAD_CONCURRENCY=2

# Đường dẫn tới yt-dlp.exe (tùy chọn, nếu không có trong PATH)
# YTDLP_PATH=C:\Tools\yt-dlp\yt-dlp.exe

# --- Cookies YouTube (TÙY CHỌN — chỉ cần khi playlist >100 video) ---
# Chọn MỘT trong hai cách:

# Cách 1 — lấy cookies tự động từ trình duyệt đã đăng nhập YouTube (Windows)
# YTDLP_COOKIES_FROM_BROWSER=edge
# YTDLP_COOKIES_FROM_BROWSER=chrome

# Cách 2 — file cookies.txt (Netscape) đặt cùng thư mục project
#   1. Đăng nhập YouTube trên Chrome/Edge
#   2. Cài extension "Get cookies.txt LOCALLY"
#   3. Export → lưu cookies.txt vào thư mục project (không commit)
# YTDLP_COOKIES=./cookies.txt
