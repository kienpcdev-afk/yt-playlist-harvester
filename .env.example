PORT=3000

# Số video tải song song (mặc định 2, tối đa 4). Mạng công ty nên đặt 1.
DOWNLOAD_CONCURRENCY=2

# Giới hạn tổng số video tải cùng lúc trên MỌI tab (khuyên 1 trên mạng công ty)
# DOWNLOAD_GLOBAL_CONCURRENCY=1

# Số lần yt-dlp retry mỗi video trước khi bỏ qua (mặc định 10, tối đa 20)
# YTDLP_RETRIES=10

# Đường dẫn tới yt-dlp.exe (tùy chọn, nếu không có trong PATH)
# YTDLP_PATH=C:\Tools\yt-dlp\yt-dlp.exe

# Đường dẫn tới ffmpeg.exe (tùy chọn). Nên dùng bản 6.x/7.x — bản cũ (4.x) mux MP4 kém ổn với Premiere.
# FFMPEG_PATH=C:\Tools\ffmpeg\bin\ffmpeg.exe

# Bỏ qua bước remux MP4 sau merge (không khuyến nghị nếu dùng Premiere)
# SKIP_MP4_REMUX=1

# JS runtime cho yt-dlp giải challenge YouTube (mặc định: node — dùng Node.js đã cài)
# YTDLP_JS_RUNTIME=node
# YTDLP_JS_RUNTIME=deno
# YTDLP_JS_RUNTIME=none

# YouTube player_client — thêm vào chuỗi fallback khi tải video (luôn thử mặc định yt-dlp trước)
# YTDLP_PLAYER_CLIENT=android,mweb,web

# Tiêu đề video: mặc định lấy tiêu đề gốc (không dịch). Đặt mã ngôn ngữ YouTube nếu muốn bản dịch.
# YTDLP_TITLE_LANG=ja
# YTDLP_TITLE_LANG=en

# --- Cookies YouTube (TÙY CHỌN — chỉ cần khi playlist >100 video) ---
# Khuyến nghị cho client: dùng auto (không cần export cookies.txt thủ công)
# YTDLP_COOKIES_FROM_BROWSER=auto
#
# Lần đầu trên Windows (Chrome/Edge): chạy một lần
#   npm run setup:browser-cookies
#   npm run setup:cookies
#
# Hoặc chỉ định trình duyệt: edge | chrome | firefox
# YTDLP_COOKIES_FROM_BROWSER=firefox
#
# Dự phòng thủ công (nếu auto không được): cookies.txt trong thư mục project
# YTDLP_COOKIES=./cookies.txt
#
# Hoặc dùng Chrome Extension trong thư mục chrome-extension/ (Developer Mode):
# mở tab YouTube đã đăng nhập → nhấn icon Extension → gửi cookie về POST /update-cookie
