PORT=3000

# Đường dẫn tới yt-dlp.exe (tùy chọn, nếu không có trong PATH)
# YTDLP_PATH=C:\Tools\yt-dlp\yt-dlp.exe

# --- Cookie YouTube (TÙY CHỌN — mặc định TẮT, comment/xóa dòng dưới để chạy như cũ) ---
# Chỉ bật khi playlist >100 video mà yt-dlp chỉ lấy được 100 mục đầu.
# Cách lấy cookies.txt:
#   1. Đăng nhập YouTube trên Chrome/Edge
#   2. Cài extension "Get cookies.txt LOCALLY" (Chrome Web Store)
#   3. Mở youtube.com → bấm extension → Export → lưu file cookies.txt
#   4. Bỏ file vào thư mục project (không commit lên Git)
#   5. Bỏ comment dòng dưới, restart server (npm start)
# YTDLP_COOKIES=./cookies.txt
